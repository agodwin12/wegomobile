# ─────────────────────────────────────────────
# WEGO MOBILE — DEVELOPMENT / LOCALHOST
# Bundled into the app as an asset. NEVER put server secrets here —
# the .env ships inside the APK and can be extracted by anyone.
# ─────────────────────────────────────────────

# API
# Android emulator reaches the host machine via 10.0.2.2
# iOS simulator / desktop: use http://localhost:10002
API_BASE_URL=http://10.0.2.2:10002/api
API_TIMEOUT=15000

# SOCKET
SOCKET_URL=http://10.0.2.2:10002
SOCKET_RECONNECT_DELAY=3000

# MAPBOX (public token)
MAPBOX_ACCESS_TOKEN=YOUR_PUBLIC_MAPBOX_TOKEN

# APP
APP_NAME=WEGO
APP_VERSION=1.0.0
ENVIRONMENT=development

# SUPPORT
SUPPORT_EMAIL=support@wegoapp.com
SUPPORT_PHONE=+237677777777

# LEGAL
TERMS_URL=https://wegoapp.com/terms
PRIVACY_URL=https://wegoapp.com/privacy

# IMAGE UPLOAD
MAX_IMAGE_SIZE=5242880
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
